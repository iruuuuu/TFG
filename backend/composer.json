{
  "name": "iesmendoza/gumip-backend",
  "description": "Backend API para GuMip - Sistema de Gestión de Cocina",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/doctrine-bundle": "^2.10",
    "doctrine/doctrine-migrations-bundle": "^3.2",
    "doctrine/orm": "^2.16",
    "lexik/jwt-authentication-bundle": "^2.19",
    "symfony/console": "6.3.*",
    "symfony/dotenv": "6.3.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "6.3.*",
    "symfony/runtime": "6.3.*",
    "symfony/security-bundle": "6.3.*",
    "symfony/yaml": "6.3.*"
  },
  "require-dev": {
    "symfony/maker-bundle": "^1.50"
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd"
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "6.3.*"
    }
  }
}
